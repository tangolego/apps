rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 클라이언트(브라우저)는 Firestore에 직접 접근하지 않고
    // 반드시 /api/... Cloud Function을 거치도록 강제한다.
    // (Admin SDK로 호출하는 Cloud Function은 이 규칙의 영향을 받지 않음)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
